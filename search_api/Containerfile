FROM python:3.11-slim

LABEL maintainer="MOJ Design System"
LABEL description="MOJ Component Search API - Semantic search for design system components"

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better layer caching
COPY requirements-api.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements-api.txt && \
    pip install --no-cache-dir gunicorn

# Copy application files
COPY api_search.py .
COPY moj_milvus_kb.py .

# Set environment variables with defaults
ENV MILVUS_HOST=milvus-standalone
ENV MILVUS_PORT=19530
ENV MILVUS_COLLECTION=knowledge_base
ENV MILVUS_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Expose the API port
EXPOSE 5000

# Add healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

# Run the application with gunicorn for production
CMD ["gunicorn", "-w", "4", "-b", "0.0.0.0:5000", "--timeout", "120", "api_search:app"]
